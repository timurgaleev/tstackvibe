#!/usr/bin/env bash
# vibestack install — register skills with Claude Code and install learnings tools
set -e

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_SRC="$REPO_DIR/skills"
CLAUDE_SKILLS="$HOME/.claude/skills"
VIBE_HOME="${VIBESTACK_HOME:-$HOME/.vibestack}"
VIBE_BIN="$VIBE_HOME/bin"

echo "Installing vibestack..."

# Create vibestack state and bin directories
mkdir -p "$VIBE_BIN"
mkdir -p "$VIBE_HOME/projects"
mkdir -p "$VIBE_HOME/analytics"

# Install bin/ scripts
if [ -d "$REPO_DIR/bin" ]; then
  for script in "$REPO_DIR/bin"/vibe-*; do
    [ -f "$script" ] || continue
    name=$(basename "$script")
    cp "$script" "$VIBE_BIN/$name"
    chmod +x "$VIBE_BIN/$name"
  done
  echo "  + vibestack tools → $VIBE_BIN"
fi

# Ensure $VIBE_BIN is on PATH (print reminder if not)
if ! echo "$PATH" | tr ':' '\n' | grep -qF "$VIBE_BIN"; then
  echo ""
  echo "  NOTE: Add $VIBE_BIN to your PATH:"
  echo "    echo 'export PATH=\"$VIBE_BIN:\$PATH\"' >> ~/.zshrc"
fi

# Install Claude Code skills
mkdir -p "$CLAUDE_SKILLS"

installed=0

for skill_dir in "$SKILLS_SRC"/*/; do
  if [ ! -f "$skill_dir/SKILL.md" ]; then
    continue
  fi

  # Read skill name from frontmatter, fall back to directory name
  skill_name=$(grep -m1 '^name:' "$skill_dir/SKILL.md" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')
  [ -z "$skill_name" ] && skill_name="$(basename "$skill_dir")"

  target="$CLAUDE_SKILLS/$skill_name"

  # Create real directory, symlink SKILL.md inside it
  mkdir -p "$target"
  ln -sfn "${skill_dir%/}/SKILL.md" "$target/SKILL.md"

  # Symlink bin/ directory if it exists (hook scripts)
  if [ -d "${skill_dir%/}/bin" ]; then
    ln -sfn "${skill_dir%/}/bin" "$target/bin"
    chmod +x "${skill_dir%/}"/bin/*.sh 2>/dev/null || true
  fi

  # Symlink all extra files and subdirectories (SKILL.md and bin/ are handled above)
  for item in "${skill_dir%/}"/*; do
    [ -e "$item" ] || continue
    item_name=$(basename "$item")
    [ "$item_name" = "SKILL.md" ] && continue
    [ "$item_name" = "bin" ] && continue
    ln -sfn "$item" "$target/$item_name"
  done

  installed=$((installed + 1))
done

echo ""
echo "Installed $installed skills → $CLAUDE_SKILLS"
echo ""
echo "Try /office-hours first in a new Claude Code session."
echo "Full skill list: ~/.claude/skills/vibestack/docs/skills.md"
echo "Uninstall: ~/.claude/skills/vibestack/uninstall"
